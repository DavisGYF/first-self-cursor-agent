# 你的大模型 API Key（例如 OpenAI/DeepSeek 兼容 Key）
OPENAI_API_KEY=your_api_key_here

# 兼容 OpenAI 的 Base URL，不同厂商按文档填写
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型名称，可在前端下拉框里覆盖
DEFAULT_MODEL=gpt-4o-mini

# 后端服务端口
PORT=3000

# SQLite 数据库文件路径（可选，默认 server/data/copilot.db）
# DATABASE_PATH=./data/copilot.db
