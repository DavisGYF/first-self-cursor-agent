# 你的大模型 API Key（例如 OpenAI/DeepSeek 兼容 Key）
OPENAI_API_KEY=your_api_key_here

# 兼容 OpenAI 的 Base URL，不同厂商按文档填写
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认模型名称，可在前端下拉框里覆盖
DEFAULT_MODEL=gpt-4o-mini

# 后端服务端口
PORT=3000

# SQLite 数据库文件路径（可选，默认 server/data/copilot.db）
# DATABASE_PATH=./data/copilot.db

# RAG（P2：段落分块 + BM25，无需向量 API）
# RAG_CHUNK_SIZE=480
# RAG_CHUNK_OVERLAP=90
# RAG_TOP_K=3
# 低于「最高分 × 此比例」的片段不注入上下文（减少弱相关胡编）
# RAG_MIN_RELATIVE_SCORE=0.22

# 设为 1 时：上传后调用 embedding API 写入向量，检索优先用语义相似度（需 OPENAI_API_KEY）
# RAG_EMBEDDING=0
# RAG_EMBEDDING_MODEL=text-embedding-3-small
