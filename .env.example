# 部署用：复制为 .env 后填写（勿提交 .env 到 Git）
#   cp .env.example .env
OPENAI_API_KEY=

# 使用 DeepSeek 等兼容网关时必填 base（模型选 deepseek-chat 时）
# OPENAI_BASE_URL=https://api.deepseek.com/v1
#
# 使用 OpenAI 官方时可不写（默认 https://api.openai.com/v1）
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEFAULT_MODEL=gpt-4o-mini
# PORT=3000

# 单次生成最大 token 数（用于控制回答长度；默认服务端是 400）
# 如果你发现“还没说完就停了”，通常就是这里/上游 max_tokens 导致
MAX_TOKENS=800
